# Volthium SC12200G4DPH 12V 200Ah pack — "The Barge Inn" (Loon Lake).
# Two physical batteries in series; their identities never change.
#
# Each BLE host sees them under a different address scheme:
#   * macOS / CoreBluetooth: a per-Mac peripheral UUID
#       (stable on a given Mac, different on each Mac)
#   * Linux / BlueZ:         the actual hardware MAC address
#       (the same on any Linux machine — it's on the radio)
#
# Filling in the Linux row:
#   .venv/bin/python scripts/scan.py
# pick out the two `V-12V200AH-*` advertisements and paste their MACs below.

# Battery A — V-12V200AH-0533
ADDR_A_DARWIN=9058AE7F-F98B-D0F6-237D-6769894DE118
ADDR_A_LINUX=

# Battery B — V-12V200AH-0667
ADDR_B_DARWIN=6EC69980-CA43-7DEF-519B-6235C8C535B7
ADDR_B_LINUX=
